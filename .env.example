# Port HTTP server (default: 8002)
PORT=8002

# Upstream endpoint
CUSTOMAI_API_URL=https://cloudfren.com/backend-api/codex/responses

# Upstream auth token (boleh raw token atau format "Bearer <token>")
CUSTOMAI_AUTH_TOKEN=

# Optional: refresh token supaya gateway bisa auto-refresh access token.
# Jika access token JWT, expiry / issuer / client_id bisa diambil otomatis dari token.
# CUSTOMAI_REFRESH_TOKEN=rt_xxx
# CUSTOMAI_TOKEN_EXPIRES_AT=1776122039541
# CUSTOMAI_TOKEN_URL=https://auth.openai.com/oauth/token
# CUSTOMAI_OAUTH_CLIENT_ID=app_xxx
# CUSTOMAI_TOKEN_SCOPES=openid profile email offline_access
# CUSTOMAI_REFRESH_BUFFER_SECONDS=300
# CUSTOMAI_TOKEN_STORE_PATH=.customai-tokens.json

# Default instructions jika request dari client tidak menyertakan system/instructions
CUSTOMAI_DEFAULT_INSTRUCTIONS=You are a helpful coding assistant.

# Optional: Cookie header untuk upstream (jika dibutuhkan)
CUSTOMAI_COOKIE=

# Optional: header tambahan ke upstream
# CUSTOMAI_UPSTREAM_ORIGIN=https://cloudfren.com
# CUSTOMAI_UPSTREAM_REFERER=https://cloudfren.com/
# CUSTOMAI_UPSTREAM_USER_AGENT=Mozilla/5.0
# CUSTOMAI_UPSTREAM_ACCEPT_LANGUAGE=en-US,en;q=0.9
#
# Atau format bebas:
# CUSTOMAI_EXTRA_HEADERS=Sec-Fetch-Mode: cors||Sec-Fetch-Site: same-origin

# Log payload JSON yang dikirim ke upstream (hati-hati berisi prompt user)
# CUSTOMAI_LOG_PAYLOAD=1
# CUSTOMAI_LOG_PAYLOAD_MAX_CHARS=4000

# Timeout request upstream dalam detik
CUSTOMAI_TIMEOUT=180

# Optional: batasi model yang boleh dipakai (comma-separated)
# CUSTOMAI_ALLOWED_MODELS=gpt-5-codex,gpt-4.1

# Optional: amankan endpoint gateway /v1/chat/completions
CUSTOMAI_GATEWAY_API_KEY=test-key
